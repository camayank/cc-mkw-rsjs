# ─────────────────────────────────────────────────────────────
# CyberComply / DigComply — environment configuration
# Issued by: DigComply Solutions Private Limited
#            (in association with CA4CPA Global LLC)
#
# Copy this file to `.env` for local dev, or set these in your
# Railway / Fly / cloud-provider environment for production.
# ─────────────────────────────────────────────────────────────

# ─── REQUIRED ────────────────────────────────────────────────

# Where the app stores client data, audit logs, qualifications, etc.
# In production, mount a persistent volume here.
DATA_DIR=./data

# JWT signing secret for portal sessions. Set ONCE in production and
# never rotate without invalidating sessions; use 32+ random bytes.
JWT_SECRET=change-me-to-a-32-byte-random-string

# Operator dashboard password. Replace before going live.
DASHBOARD_PASSWORD=change-me

# Public base URL of the deployment (used in magic links, reset emails).
BASE_URL=https://app.your-domain.com

# Comma-separated list of allowed CORS origins.
ALLOWED_ORIGINS=https://www.your-domain.com,https://app.your-domain.com


# ─── REQUIRED for production: operator MFA ───────────────────
#
# When OPERATOR_MFA_SECRET is set, every operator login requires a TOTP
# code. Generate the secret via POST /api/operator/mfa/setup-secret with
# ?password=<dashboard pw>; copy the returned base32 secret here AND
# add it to your authenticator app. Restart to enforce.
#
# OPERATOR_MFA_SECRET=

# Set to "1" ONLY in test environments to bypass operator MFA.
# Never set this in production.
# OPERATOR_MFA_DISABLED=


# ─── REQUIRED for password resets ────────────────────────────

# Independent secret for HMAC-signed reset tokens. Falls back to
# JWT_SECRET if unset, but a separate value is recommended.
RESET_TOKEN_SECRET=change-me-to-a-different-32-byte-random-string


# ─── OPTIONAL: AI / agent integrations ───────────────────────
#
# Without these, AI-generated narratives and policies are skipped and
# the portal continues to render the underlying data without claiming
# AI features are active.

# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=


# ─── OPTIONAL: Dark web monitoring ───────────────────────────
#
# Without an HIBP key the portal shows "Pending setup · HIBP key required"
# for the dark-web tile and never claims credentials are clean.

# HIBP_API_KEY=


# ─── OPTIONAL: Vulnerability scanning ────────────────────────
#
# Nuclei must be on the runner's PATH. Without it the vuln-scan tile
# shows "Pending setup · scanner not connected".


# ─── OPTIONAL: Phishing simulation (Professional+ tiers) ─────
#
# GoPhish — without these, phishing-readiness shows "Not connected".

# GOPHISH_API_KEY=
# GOPHISH_URL=


# ─── OPTIONAL: Microsoft 365 monitoring (Essentials+) ────────
#
# Without all three, the identity / M365 monitoring service shows
# "Not connected" and the operator is told to authorize read-only access.

# MS_TENANT_ID=
# MS_CLIENT_ID=
# MS_CLIENT_SECRET=


# ─── OPTIONAL: Apex active security validation ───────────────
#
# Active validation also requires a separately-signed legal authorization
# scope. The binary path defaults to "pensar" on PATH.

# APEX_BIN=pensar


# ─── OPTIONAL: Stripe billing ────────────────────────────────
#
# Without these, invoice creation and webhook tier-promotion are
# unavailable and the dashboard shows "Stripe key required".

# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=


# ─── OPTIONAL: Outbound email ────────────────────────────────
#
# Used for free-scan PDF delivery, password reset links, magic-link
# setup, and operator alerts. Without these, emails are skipped and
# the relevant flows surface "Pending setup" rather than claiming
# delivery — but you cannot run the customer-facing reset flow until
# an SMTP transport is configured.

# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Operator alert recipient.
# OPERATOR_NOTIFY_EMAIL=


# ─── OPTIONAL: Calendar / advisor scheduling ─────────────────

# CALENDAR_LINK=https://calendly.com/your-advisor/30min


# ─── OPTIONAL: Customer support contact ──────────────────────

# SUPPORT_EMAIL=support@your-domain.com


# ─── DO NOT SET in production ────────────────────────────────
#
# These bypass production safety rails. The test harness sets them
# automatically; your live environment must not.

# BYPASS_PASSWORD_POLICY=
# OPERATOR_MFA_DISABLED=
